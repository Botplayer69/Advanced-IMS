# Supabase Postgres connection string.
# Prefer the TRANSACTION POOLER URL (IPv4-friendly) from:
#   Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
# Example format:
# DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# JWT secret for signing access tokens — generate with: openssl rand -hex 32
JWT_SECRET=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
